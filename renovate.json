{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "matchManagers": ["dockerfile"],
      "semanticCommitType": "chore",
      "semanticCommitScope": "docker"
    }
  ],
  "rust": {
    "enabled": true
  }
}
