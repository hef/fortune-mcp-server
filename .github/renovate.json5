{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "platformAutomerge": true,
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "automerge": true
    },
    {
      "matchManagers": ["dockerfile"],
      "semanticCommitType": "chore",
      "semanticCommitScope": "docker",
      "automerge": true
    }
  ],
  "rust": {
    "enabled": true
  }
}
